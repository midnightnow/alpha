## VI. THE GEOMETRIC VALIDATION

**How we know it's working correctly**:

### Test 1: The 60-Vector Field
```typescript
function test60VectorField() {
  const npc1 = createNPC({ x: 0, y: 0 })
  const npc2 = createNPC({ x: 10, y: 0 })

  const vectors1 = generate60Vectors(npc1)
  const vectors2 = generate60Vectors(npc2)

  assert(vectors1.length === 60)
  assert(vectors2.length === 60)

  // Verify 6° spacing
  for (let i = 0; i < 59; i++) {
    const angle = angleBetween(vectors1[i], vectors1[i+1])
    assert(Math.abs(angle - (Math.PI / 30)) < 0.001)  // 6° = π/30 radians
  }
}
```

### Test 2: The Π-Frame Ratio
```typescript
function testPiFrameRatio() {
  const frame = new PiFrame()

  const totalMaterial = frame.leftPier.height + frame.rightPier.height + frame.lintel.length
  assert(totalMaterial === 22)  // 7 + 7 + 8 = 22

  const ratio = totalMaterial / frame.leftPier.height
  assert(Math.abs(ratio - 22/7) < 0.001)  // Should equal π approximation
}
```

### Test 3: The PLATO Cycle
```typescript
function testPLATOCycle() {
  const npc = createNPC()
  const stateLog = []

  for (let i = 0; i < 500; i++) {
    updateNPC(npc, 0.016)  // 60 FPS
    if (npc.state !== stateLog[stateLog.length - 1]) {
      stateLog.push(npc.state)
    }
  }

  // Should cycle through P→L→A→T→O→P multiple times
  assert(stateLog.includes('P'))
  assert(stateLog.includes('L'))
  assert(stateLog.includes('A'))
  assert(stateLog.includes('T'))
  assert(stateLog.includes('O'))

  // Count complete cycles
  const cycles = countSequence(stateLog, ['P', 'L', 'A', 'T', 'O'])
  assert(cycles > 0)  // At least one complete cycle in 500 frames
}
```

### Test 4: The 12.37% Slop
```typescript
function testHadesGap() {
  const positions = []
  const idealPosition = { x: 100, y: 100 }

  for (let i = 0; i < 1000; i++) {
    const actual = placePiFrame(idealPosition)
    positions.push(actual)
  }

  const deviations = positions.map(p =>
    Math.abs(Vector2.distance(p, idealPosition) / Vector2.distance(idealPosition, {x:0, y:0}))
  )

  const averageDeviation = mean(deviations)
  assert(averageDeviation < 0.1237)  // Should be within Hades Gap
  assert(averageDeviation > 0)  // Should have SOME wobble (not perfect)
}
```

