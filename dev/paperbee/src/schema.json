{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "PaperBeeManifest",
    "type": "object",
    "properties": {
        "research_title": {
            "type": "string"
        },
        "hardcard_template_id": {
            "type": "string",
            "default": "hc_v2_academic"
        },
        "source_logic_summary": {
            "type": "string"
        },
        "visual_intent": {
            "type": "string"
        },
        "reference_styles": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "methodology": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "feature": {
                        "type": "string"
                    },
                    "logic": {
                        "type": "string"
                    },
                    "rationale": {
                        "type": "string"
                    },
                    "equations": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "data_payload": {
            "type": "object",
            "properties": {
                "x_axis": {
                    "type": "string"
                },
                "y_axis": {
                    "type": "string"
                },
                "values": {
                    "type": "array"
                }
            }
        },
        "architecture_nodes": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "label": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string"
                    }
                }
            }
        }
    },
    "required": [
        "research_title",
        "source_logic_summary",
        "visual_intent"
    ]
}